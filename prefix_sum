//psum[i] = soma dos elementos de 0 a i-1 do vetor.
vi v;
vector<ll> psum(n+1,0);
for(int i=0; i<n; i++){
    psum[i+1] = psum[i] +v[i];
    //cout<<"PSUM["<<i<<"] = "<<psum[i]<<endl;
}
//cout<<"PSUM["<<n<<"] = "<<psum[n]<<endl;
vector<ll> isum(n+1,0);
for(int i=n; i>0; i--){
    isum[i-1] = isum[i]+v[i-1];
    //cout<<"ISUM["<<i-1<<"] = "<<isum[i-1]<<endl;
}
cout<<"ISUM["<<n<<"] = "<<isum[n]<<endl;
