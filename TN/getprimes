vector<pair<int, int>> getprimes(int n) {
    vector<pair<int, int>> primes;

    for (int i = 2; i * i <= n; i++) {
        int cnt = 0;

        while (n % i == 0) {
            n /= i;
            cnt++;
        }

        if (cnt > 0) primes.push_back({i, cnt});
    }

    if (n > 1) primes.push_back({n, 1});
    return primes;
}
