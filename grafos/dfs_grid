const int MAXSZ = 60;
char grid[MAXSZ][MAXSZ];

bool vis[MAXSZ][MAXSZ]; //INICIA EM FALSO

const int dx[] = {1,0,0,-1};
const int dy[] = {0,1,-1,0};

bool valid(int x, int y,int tamx, int tamy){
    return x>=0 && x<tamx && y>=0 && y<tamy && grid[x][y] != '#' && !vis[x][y];
}


void dfs(int x,int y,int tamx,int tamy){
    vis[x][y] = true;
    for(int d=0;d<4;d++){
        int ax = x+dx[d], ay = y+dy[d];
        if(!valid(ax,ay,tamx,tamy)) continue;
        dfs(ax,ay,tamx,tamy);
    }
}
