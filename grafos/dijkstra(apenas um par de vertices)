#include <bits/stdc++.h>
#define endl '\n'

using namespace std;
using ll = long long;
using pii = pair<int,int>;
using vi = vector<int>;
#define int ll //SE LIGA!!!
const int MAXSZ = 1e5 + 10;

vector<ll> dist(MAXSZ + 1, LLONG_MAX);

vector<vector<tuple<ll, ll>>> adj(MAXSZ + 1);


void addEdge(ll u, ll v, ll w){
    adj[u].push_back({v,w});
}


void dijkstra(int vtx_ini) {
    priority_queue< tuple<ll, ll>, vector<tuple<ll, ll>>, greater<tuple<ll, ll>>> pq;

    pq.push({0, vtx_ini});
    dist[vtx_ini] = 0;
    while (!pq.empty()) {
        auto el = pq.top();
        auto d = get<0>(el);
        auto v = get<1>(el);
        pq.pop();

        if (d <= dist[v]) {
            for (auto ar : adj[v]) {
                auto u = get<0>(ar);
                auto w = get<1>(ar);
                if (dist[u] > dist[v] + w) {
                    dist[u] = dist[v] + w;
                    pq.push({dist[u], u});
                }
            }
        }
    }
}
