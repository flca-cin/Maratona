#include <bits/stdc++.h>
#define endl '\n'

using namespace std;
using ll = long long;
using pii = pair<int,int>;
using vi = vector<int>;

const int MAXSZ = 1e5 + 10;
vector<ll> dist(MAXSZ + 1, LLONG_MAX);
vector<bool> vis(MAXSZ + 1, false);
vector<vector<tuple<ll, ll>>> adj(MAXSZ + 1);



int main(){
    int n;

    dist[1] = 0;
    for (int i = 0; i < n; i++) {
        int v = -1;
        ll mn = LLONG_MAX;

        for (int j = 1; j <= n; j++) {
            if ((!vis[j]) && (dist[j] < mn)) {
                mn = dist[j];
                v = j;
            }
        }

        if (v == -1) break;

        vis[v] = true;
        for (auto [u, w] : adj[v]) {
            if (dist[u] > dist[v] + w) {
                dist[u] = dist[v] + w;
            }
        }
    }
    return 0;
}

