#include <bits/stdc++.h>
#define endl '\n'

using namespace std;
using ll = long long;
using pii = pair<int,int>;
using vi = vector<int>;

int n;

const int MAXSZ = 300 + 10;
const ll INF = LLONG_MAX;
vector<vector<ll>> dist(MAXSZ + 1, vector<ll>(MAXSZ + 1));


void init(int n){
    for(int i=1;i<=n;i++){
        for(int j=1;j<=n;j++){
            dist[i][j] = INF;
        }
    }
    for(int i=1;i<=n;i++){
        dist[i][i]=0;
    }
}

void addEdge (int u, int v, ll w){
    dist[u][v] = w;
    dist[v][u] = w;
}

void removeEdge (int u, int v){
    dist[u][v] = INF;
    dist[v][u] = INF;
}


// Cuidado com múltiplas arestas (pegue o mínimo)
// dist[i][j] deve ser 0 se (i == j)

int main(){
    
    cin>>n;
    init(n);
    for (int k = 1; k <= n; k++) {
        for (int u = 1; u <= n; u++) {
            for (int v = 1; v <= n; v++) {
                if (dist[u][k] != LLONG_MAX &&
                    dist[k][v] != LLONG_MAX) {
                    dist[u][v] = min(dist[u][v],
                                    dist[u][k] + dist[k][v]);
                }
            }
        }
    }

    return 0;
}

