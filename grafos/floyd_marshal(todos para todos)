#include <bits/stdc++.h>
#define endl '\n'

using namespace std;
using ll = long long;
using pii = pair<int,int>;
using vi  = vector<int>;

int n;

const int MAXSZ = 300 + 10;
const ll INF = LLONG_MAX;
vector<vector<ll>> dist(MAXSZ + 1, vector<ll>(MAXSZ + 1));

void init(int n){
    for (int i = 1; i <= n; i++){
        for (int j = 1; j <= n; j++){
            dist[i][j] = INF;
        }
    }
    for (int i = 1; i <= n; i++){
        dist[i][i] = 0;
    }
}

void addEdge (int u, int v, ll w){
    dist[u][v] = w;
    dist[v][u] = w;
}

void removeEdge (int u, int v){
    dist[u][v] = INF;
    dist[v][u] = INF;
}

// Floyd–Warshall em função
void floydWarshall(int n){
    for (int k = 1; k <= n; k++) {
        for (int u = 1; u <= n; u++) {
            for (int v = 1; v <= n; v++) {
                if (dist[u][k] != INF && dist[k][v] != INF) {
                    dist[u][v] = min(dist[u][v],
                                     dist[u][k] + dist[k][v]);
                }
            }
        }
    }
}

int main(){
    //freopen("input.txt", "r", stdin); freopen("output.txt", "w", stdout);
    cout << setprecision(10) << fixed;
    ios::sync_with_stdio(false); cin.tie(0);
    cin >> n;
    init(n);

    // aqui você pode chamar addEdge(u, v, w) várias vezes
    // ex.: addEdge(1, 2, 5);

    floydWarshall(n);

    return 0;
}
