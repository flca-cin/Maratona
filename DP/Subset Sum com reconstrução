#include <bits/stdc++.h>
#define endl '\n'

using namespace std;
using ll = long long;
using pii = pair<int,int>;
using vi = vector<int>;
#define int ll //SE LIGA!!!

bool solve() {
    int t;   // alvo
    cin >> t;
    int tam;
    cin >> tam;

    vector<int> a(tam);
    for (int i = 0; i < tam; i++) {
        cin >> a[i];
    }

    vector<bool> dp(t + 1, false);
    dp[0] = true;

    // para reconstrução
    vector<int> parent(t + 1, -1); // soma anterior
    vector<int> take(t + 1, -1);   // índice do elemento usado

    for (int idx = 0; idx < tam; ++idx) {
        int x = a[idx];
        for (int i = t - x; i >= 0; --i) {
            if (dp[i] && !dp[i + x]) { 
                dp[i + x] = true;
                parent[i + x] = i;
                take[i + x] = idx;
            }
        }
    }

    if (!dp[t]) {
        cout << 0 << endl; // não existe subset
        return false;
    }

    // reconstrução do subset que soma t
    vector<int> subset;
    int sum = t;
    while (sum > 0) {
        int idx = take[sum];
        subset.push_back(a[idx]);
        sum = parent[sum];
    }
    reverse(subset.begin(), subset.end());

    // imprime o subset (pode ajustar o formato conforme o problema)
    cout << 1 << endl; // existe subset (ou tira isso e só imprime o subset)
    for (int x : subset) {
        cout << x << " ";
    }
    cout << endl;

    return true;
}

signed main() {
    //freopen("input.txt", "r", stdin); freopen("output.txt", "w", stdout);
    cout << setprecision(10) << fixed;
    ios::sync_with_stdio(false); 
    cin.tie(0);

    int tc; 
    tc = 1; 
    for (int i = 1; i <= tc; i++) {
        solve();
    }

    return 0;
}
