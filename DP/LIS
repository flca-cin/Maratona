#include <bits/stdc++.h>
#define endl '\n'

using namespace std;
using ll = long long;
using pii = pair<int,int>;
using vi = vector<int>;
#define int ll //SE LIGA!!!

int solve() {
    int n;
    cin>>n;
    vi a(n);
    for(int i=0;i<n;i++){
        cin>>a[i];
    }

    int answer = 0;
    vector<int> dp(n);

    for (int j = 0; j < n; ++j) {
        dp[j] = 1;
        for (int i = j - 1; i >= 0; --i) {
            if (a[i] < a[j]) {
                dp[j] = max(dp[j], dp[i] + 1);
            }
        }
        answer = max(answer, dp[j]);
    }

    return answer;
}


signed main(){
    //freopen("input.txt", "r", stdin); freopen("output.txt", "w", stdout);
    cout << setprecision(10) << fixed;
    ios::sync_with_stdio(false); cin.tie(0);


    int tc; tc=1; for(int i=1;i<=tc;i++){
        cout<<solve();
    }
    

    return 0;
}
