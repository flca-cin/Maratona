int n;
int g[20][20];
int dp[20][1<<20];

int solve(int i, int mask){
    if(mask == (1<<n) - 1){
        return g[i][0];
    }

    int& ans = dp[i][mask];
    if(ans != -1) return ans;

    ans = 2e9;
    for(int j = 0; j < n; j++){
        if(mask & (1<<j)) continue;
        ans = min(ans, g[i][j] + solve(j, mask ^ (1<<j)));
    }
    return ans;
}
