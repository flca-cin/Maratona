int best(int i, int j) {
    if (i < 0 || j < 0) return 0;
    if (dp[i][j] != -1) return dp[i][j];

    dp[i][j] = 0;

    if (a[i] == b[j]) {
        dp[i][j] = 1 + best(i - 1, j - 1);
    } else {
        dp[i][j] = max(best(i - 1, j), best(i, j - 1));
    }

    return dp[i][j];
}

int solve() {
